JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Mapbox (for web & mobile)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
