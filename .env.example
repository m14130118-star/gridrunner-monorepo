# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=gridrunner
DB_PASSWORD=gridrunner_password
DB_NAME=gridrunner_db
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
